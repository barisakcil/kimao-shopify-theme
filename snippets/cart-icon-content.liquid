<span class="icon-swap">
  {%- comment -%} Outline bag (normal state) {%- endcomment -%}
  <svg class="icon-outline" viewBox="0 0 24 24" fill="none" stroke="currentColor"
       stroke-width="1.2" stroke-linecap="square" stroke-linejoin="miter">
    <path d="M6 7h12a1 1 0 0 1 1 1v10a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V8a1 1 0 0 1 1-1z"/>
    <path d="M9 7V5a3 3 0 0 1 6 0v2"/>
    {%- if cart.item_count > 0 and cart.item_count < 100 -%}
      <text x="12" y="16.5" text-anchor="middle" fill="currentColor" stroke="none"
            font-size="7" font-weight="600">{{ cart.item_count }}</text>
    {%- endif -%}
  </svg>
  {%- comment -%} Filled bag (hover state) {%- endcomment -%}
  <svg class="icon-filled" viewBox="0 0 24 24" stroke="currentColor"
       stroke-width="1.2" stroke-linecap="square" stroke-linejoin="miter">
    <path d="M6 7h12a1 1 0 0 1 1 1v10a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V8a1 1 0 0 1 1-1z" fill="currentColor"/>
    <path d="M9 7V5a3 3 0 0 1 6 0v2" fill="none"/>
    {%- if cart.item_count > 0 and cart.item_count < 100 -%}
      <text class="cart-count-filled" x="12" y="16.5" text-anchor="middle" stroke="none"
            font-size="7" font-weight="600">{{ cart.item_count }}</text>
    {%- endif -%}
  </svg>
</span>
<span class="visually-hidden">{{ 'templates.cart.cart' | t }}</span>
{%- if cart != empty -%}
  <span class="visually-hidden">{{ 'sections.header.cart_count' | t: count: cart.item_count }}</span>
{%- endif -%}
