{% comment %}
  Kimao — Custom Navigation Drawer
{% endcomment %}

<script>
  document.addEventListener('DOMContentLoaded', function () {
    document.querySelectorAll('.kimao-drawer__accordion').forEach(function (details) {
      var summary = details.querySelector('summary');
      var sub = details.querySelector('.kimao-drawer__sub');
      if (!summary || !sub) return;

      summary.addEventListener('click', function (e) {
        if (details.open) {
          e.preventDefault();
          var anim = sub.animate(
            [{ opacity: 1, transform: 'translateY(0)' }, { opacity: 0, transform: 'translateY(-6px)' }],
            { duration: 250, easing: 'ease', fill: 'forwards' }
          );
          anim.onfinish = function () {
            details.open = false;
            anim.cancel();
          };
        }
      });
    });
  });
</script>

<header-drawer data-breakpoint="{% if section.settings.menu_type_desktop == 'drawer' %}desktop{% else %}tablet{% endif %}">
  <details id="Details-menu-drawer-container" class="menu-drawer-container">
    <summary
      class="header__icon header__icon--menu header__icon--summary link focus-inset"
      aria-label="{{ 'sections.header.menu' | t }}"
    >
      <span>
        {{- 'icon-hamburger.svg' | inline_asset_content -}}
        {{- 'icon-close.svg' | inline_asset_content -}}
      </span>
    </summary>

    <div id="menu-drawer" class="menu-drawer motion-reduce gradient color-{{ section.settings.menu_color_scheme }} kimao-drawer">
      <div class="kimao-drawer__inner">

        {%- comment -%} HEADER BAR {%- endcomment -%}
        <div class="kimao-drawer__header">
          <span class="kimao-drawer__label">MENÜ</span>
          <button
            class="kimao-drawer__close-btn"
            onclick="document.querySelector('#Details-menu-drawer-container summary').click()"
            aria-label="Menüyü kapat"
          >&#x2715;</button>
        </div>

        {%- comment -%} NAV {%- endcomment -%}
        <nav class="kimao-drawer__nav">

          {%- comment -%} 1. KATEGORİLER accordion {%- endcomment -%}
          <details class="kimao-drawer__item kimao-drawer__accordion">
            <summary class="kimao-drawer__row">
              <span class="kimao-drawer__title">Kategoriler</span>
              <span class="kimao-drawer__icon" aria-hidden="true"></span>
            </summary>
            <div class="kimao-drawer__sub">
              <a href="/collections/serum" class="kimao-drawer__sub-link">Serum</a>
              <a href="/collections/krem" class="kimao-drawer__sub-link">Krem</a>
              <a href="/collections/tonik" class="kimao-drawer__sub-link">Tonik</a>
              <a href="/collections/set-bundle" class="kimao-drawer__sub-link">Set / Bundle</a>
            </div>
          </details>

          {%- comment -%} 2. TÜM ÜRÜNLER {%- endcomment -%}
          <div class="kimao-drawer__item">
            <a href="/collections/all" class="kimao-drawer__row kimao-drawer__row--link">
              <span class="kimao-drawer__title">Tüm Ürünler</span>
            </a>
          </div>

          {%- comment -%} 3. INFO accordion {%- endcomment -%}
          <details class="kimao-drawer__item kimao-drawer__accordion">
            <summary class="kimao-drawer__row">
              <span class="kimao-drawer__title">Info</span>
              <span class="kimao-drawer__icon" aria-hidden="true"></span>
            </summary>
            <div class="kimao-drawer__sub">
              <a href="/pages/sss" class="kimao-drawer__sub-link">S.S.S.</a>
              <a href="/pages/kargo-iade-degisim" class="kimao-drawer__sub-link">Kargo İade Değişim</a>
              <a href="/pages/iletisim" class="kimao-drawer__sub-link">İletişim</a>
              <a href="/pages/politikalar" class="kimao-drawer__sub-link">Politikalar</a>
              <a href="/account" class="kimao-drawer__sub-link">Hesabım</a>
            </div>
          </details>

          {%- comment -%} 4. İÇERİK {%- endcomment -%}
          <div class="kimao-drawer__item">
            <a href="/pages/icerik" class="kimao-drawer__row kimao-drawer__row--link">
              <span class="kimao-drawer__title">İçerik</span>
            </a>
          </div>

        </nav>

        {%- comment -%} BOTTOM BAR {%- endcomment -%}
        <div class="kimao-drawer__bottom">
          <a href="/account" class="kimao-drawer__bottom-item">Hesabım</a>
          <a href="/cart" class="kimao-drawer__bottom-item">Sepet</a>
        </div>

      </div>
    </div>
  </details>
</header-drawer>
