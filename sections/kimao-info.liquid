<style>
  .kimao-info-{{ section.id }} {
    display: flex;
    width: 100%;
    min-height: 100vh;
  }

  /* Left column: boxes */
  .kimao-info-{{ section.id }} .ki-boxes {
    width: {{ section.settings.left_width }}%;
    background-color: {{ section.settings.box_bg_color }};
  }

  .kimao-info-{{ section.id }} .ki-box {
    position: relative;
    border-bottom: 1px solid #000;
    border-right: 1px solid #000;
    cursor: pointer;
    padding: 30px 40px;
  }

  .kimao-info-{{ section.id }} .ki-box:first-child {
    border-top: 1px solid #000;
  }

  .kimao-info-{{ section.id }} .ki-box::before {
    content: '';
    position: absolute;
    inset: 0;
    background: #000;
    width: 0;
    z-index: 0;
    overflow: hidden;
    transition: width 500ms cubic-bezier(0.25, 0.1, 0.25, 1);
  }

  .kimao-info-{{ section.id }} .ki-box.is-active::before {
    width: 100%;
  }

  .kimao-info-{{ section.id }} .ki-box-content {
    position: relative;
    z-index: 1;
    color: {{ section.settings.box_text_color }};
    transition: color 500ms cubic-bezier(0.25, 0.1, 0.25, 1);
  }

  .kimao-info-{{ section.id }} .ki-box-content p {
    margin: 0;
    font-size: {{ section.settings.box_font_size }}px;
    font-weight: {{ section.settings.box_font_weight }};
    line-height: 1.3;
    overflow-wrap: break-word;
    word-wrap: break-word;
  }

  .kimao-info-{{ section.id }} .ki-box.is-active .ki-box-content {
    color: {{ section.settings.box_active_text_color }};
  }

  /* Right column: sticky image + answer panels */
  .kimao-info-{{ section.id }} .ki-right {
    width: {{ 100 | minus: section.settings.left_width }}%;
    position: sticky;
    top: var(--header-height, 0px);
    height: calc(100vh - var(--header-height, 0px));
    overflow: hidden;
  }

  .kimao-info-{{ section.id }} .ki-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  /* Answer panels */
  .kimao-info-{{ section.id }} .ki-answer {
    position: absolute;
    inset: 0;
    background-color: {{ section.settings.answer_bg_color }};
    color: {{ section.settings.answer_text_color }};
    transform: translateX(100%);
    transition: transform 500ms cubic-bezier(0.25, 0.1, 0.25, 1);
    z-index: 2;
    display: flex;
    flex-direction: column;
    padding: 50px 60px;
    overflow-y: auto;
  }

  .kimao-info-{{ section.id }} .ki-answer.is-active {
    transform: translateX(0);
  }

  .kimao-info-{{ section.id }} .ki-answer.is-exiting {
    transform: translateX(-100%);
  }

  /* Close button */
  .kimao-info-{{ section.id }} .ki-answer-close {
    position: absolute;
    top: clamp(12px, 1.25vw, 24px);
    left: clamp(12px, 1.25vw, 24px);
    width: 40px;
    height: 40px;
    background: none;
    border: 1px solid currentColor;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0;
    color: {{ section.settings.answer_text_color }};
    z-index: 3;
    transition: opacity 200ms ease;
  }

  .kimao-info-{{ section.id }} .ki-answer-close:hover {
    opacity: 0.6;
  }

  .kimao-info-{{ section.id }} .ki-answer-close svg {
    width: 14px;
    height: 14px;
  }

  /* Answer content */
  .kimao-info-{{ section.id }} .ki-answer-content {
    margin-top: 20px;
  }

  .kimao-info-{{ section.id }} .ki-answer-content p {
    margin: 0 0 1em;
    font-size: {{ section.settings.answer_font_size }}px;
    font-weight: {{ section.settings.answer_font_weight }};
    line-height: 1.6;
  }

  .kimao-info-{{ section.id }} .ki-answer-content p:last-child {
    margin-bottom: 0;
  }

  /* Mobile accordion answer - hidden on desktop */
  .kimao-info-{{ section.id }} .ki-box-answer-mobile {
    display: none;
  }

  @media screen and (max-width: 749px) {
    .kimao-info-{{ section.id }} {
      min-height: auto;
    }

    .kimao-info-{{ section.id }} .ki-boxes {
      width: 100%;
    }

    .kimao-info-{{ section.id }} .ki-box {
      border-right: none;
      padding: 0;
    }

    .kimao-info-{{ section.id }} .ki-box::before {
      display: none;
    }

    .kimao-info-{{ section.id }} .ki-box-content {
      padding: 30px 40px;
    }

    .kimao-info-{{ section.id }} .ki-box-content::before {
      content: '';
      position: absolute;
      inset: 0;
      background: #000;
      width: 0;
      z-index: -1;
      overflow: hidden;
      transition: width 500ms cubic-bezier(0.25, 0.1, 0.25, 1);
    }

    .kimao-info-{{ section.id }} .ki-box.is-active .ki-box-content::before {
      width: 100%;
    }

    .kimao-info-{{ section.id }} .ki-right {
      display: none;
    }

    .kimao-info-{{ section.id }} .ki-box-answer-mobile {
      display: grid;
      grid-template-rows: 0fr;
      transition: grid-template-rows 400ms ease;
      position: relative;
      z-index: 2;
      background-color: {{ section.settings.answer_bg_color }};
    }

    .kimao-info-{{ section.id }} .ki-box.is-active .ki-box-answer-mobile {
      grid-template-rows: 1fr;
    }

    .kimao-info-{{ section.id }} .ki-box-answer-mobile-inner {
      overflow: hidden;
      padding: 0 40px;
    }

    .kimao-info-{{ section.id }} .ki-box-answer-mobile-inner p {
      margin: 0 0 1em;
      font-size: {{ section.settings.answer_font_size }}px;
      font-weight: {{ section.settings.answer_font_weight }};
      line-height: 1.6;
      color: {{ section.settings.answer_text_color }};
    }

    .kimao-info-{{ section.id }} .ki-box-answer-mobile-inner p:first-child {
      padding-top: 20px;
    }

    .kimao-info-{{ section.id }} .ki-box-answer-mobile-inner p:last-child {
      margin-bottom: 0;
      padding-bottom: 10px;
    }
  }
</style>

<div class="kimao-info-{{ section.id }}" data-section-id="{{ section.id }}">
  {%- comment -%} Left column: clickable boxes {%- endcomment -%}
  <div class="ki-boxes">
    {%- for block in section.blocks -%}
      <div class="ki-box" data-index="{{ forloop.index0 }}" {{ block.shopify_attributes }}>
        <div class="ki-box-content">{{ block.settings.heading }}</div>
        <div class="ki-box-answer-mobile"><div class="ki-box-answer-mobile-inner">{{ block.settings.answer }}</div></div>
      </div>
    {%- endfor -%}
  </div>

  {%- comment -%} Right column: image + answer panels {%- endcomment -%}
  <div class="ki-right">
    {%- if section.settings.image != blank -%}
      <img
        class="ki-image"
        src="{{ section.settings.image | image_url: width: 900 }}"
        srcset="{{ section.settings.image | image_url: width: 300 }} 300w,
                {{ section.settings.image | image_url: width: 450 }} 450w,
                {{ section.settings.image | image_url: width: 600 }} 600w,
                {{ section.settings.image | image_url: width: 900 }} 900w"
        sizes="(max-width: 749px) 100vw, {{ 100 | minus: section.settings.left_width }}vw"
        alt="{{ section.settings.image.alt | escape }}"
        width="{{ section.settings.image.width }}"
        height="{{ section.settings.image.height }}"
        loading="lazy"
      >
    {%- else -%}
      <div class="ki-image" style="background: #e0e0e0;"></div>
    {%- endif -%}

    {%- for block in section.blocks -%}
      <div class="ki-answer" data-answer="{{ forloop.index0 }}">
        <button class="ki-answer-close" aria-label="Close">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round">
            <line x1="1" y1="1" x2="13" y2="13"/>
            <line x1="13" y1="1" x2="1" y2="13"/>
          </svg>
        </button>
        <div class="ki-answer-content">{{ block.settings.answer }}</div>
      </div>
    {%- endfor -%}
  </div>
</div>

<script>
  (function() {
    var SECTION_ID = '{{ section.id }}';

    function init(container) {
      if (!container) return;

      var boxes = container.querySelectorAll('.ki-box');
      var answers = container.querySelectorAll('.ki-answer');
      var closeBtns = container.querySelectorAll('.ki-answer-close');
      var activeIndex = -1;

      function getAnswer(idx) {
        return container.querySelector('.ki-answer[data-answer="' + idx + '"]');
      }

      function getBox(idx) {
        return container.querySelector('.ki-box[data-index="' + idx + '"]');
      }

      function closeActive(slideDirection) {
        if (activeIndex === -1) return;

        var oldAnswer = getAnswer(activeIndex);
        var oldBox = getBox(activeIndex);

        if (oldBox) oldBox.classList.remove('is-active');

        if (oldAnswer) {
          if (slideDirection === 'left') {
            oldAnswer.classList.add('is-exiting');
            oldAnswer.classList.remove('is-active');
          } else {
            /* slide back to right */
            oldAnswer.classList.remove('is-active');
          }

          var cleanup = function(e) {
            if (e.target !== oldAnswer) return;
            oldAnswer.style.transition = 'none';
            oldAnswer.classList.remove('is-exiting');
            oldAnswer.offsetHeight;
            oldAnswer.style.transition = '';
            oldAnswer.removeEventListener('transitionend', cleanup);
          };
          oldAnswer.addEventListener('transitionend', cleanup);
        }

        activeIndex = -1;
      }

      function openBox(idx) {
        var answer = getAnswer(idx);
        var box = getBox(idx);

        if (answer) {
          /* Force the panel to start from the right */
          answer.style.transition = 'none';
          answer.classList.remove('is-exiting');
          answer.style.transform = 'translateX(100%)';
          /* Force reflow */
          answer.offsetHeight;
          answer.style.transition = '';
          answer.style.transform = '';
          answer.classList.add('is-active');
        }

        if (box) box.classList.add('is-active');
        activeIndex = idx;
      }

      function handleBoxClick(e) {
        var box = e.currentTarget;
        var idx = parseInt(box.getAttribute('data-index'), 10);

        if (idx === activeIndex) {
          /* Same box: close (slide right) */
          closeActive('right');
        } else if (activeIndex !== -1) {
          /* Different box: slide old left, new from right */
          closeActive('left');
          openBox(idx);
        } else {
          /* Nothing open: slide new from right */
          openBox(idx);
        }
      }

      function handleClose() {
        closeActive('right');
      }

      /* At boundary: forward scroll to page with capped delta to prevent jumps */
      var MAX_DELTA = 30;

      function handleWheel(e) {
        if (activeIndex === -1) return;
        var activeAnswer = getAnswer(activeIndex);
        if (!activeAnswer) return;
        if (!activeAnswer.contains(e.target)) return;

        var scrollTop = activeAnswer.scrollTop;
        var scrollHeight = activeAnswer.scrollHeight;
        var clientHeight = activeAnswer.clientHeight;
        var delta = e.deltaY;

        var atTop = scrollTop <= 0 && delta < 0;
        var atBottom = scrollTop + clientHeight >= scrollHeight - 1 && delta > 0;

        if (atTop || atBottom) {
          e.preventDefault();
          var capped = Math.sign(delta) * Math.min(Math.abs(delta), MAX_DELTA);
          window.scrollBy(0, capped);
        }
      }

      container.addEventListener('wheel', handleWheel, { passive: false });

      /* Bind events */
      for (var i = 0; i < boxes.length; i++) {
        boxes[i].addEventListener('click', handleBoxClick);
      }

      for (var j = 0; j < closeBtns.length; j++) {
        closeBtns[j].addEventListener('click', function(e) {
          e.stopPropagation();
          handleClose();
        });
      }
    }

    /* Initial load */
    var el = document.querySelector('.kimao-info-' + SECTION_ID);
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', function() {
        init(document.querySelector('.kimao-info-' + SECTION_ID));
      });
    } else {
      init(el);
    }

    /* Shopify editor reload */
    document.addEventListener('shopify:section:load', function(e) {
      if (e.detail.sectionId === SECTION_ID) {
        init(e.target.querySelector('.kimao-info-' + SECTION_ID));
      }
    });
  })();
</script>

{% schema %}
{
  "name": "Kimao Info",
  "tag": "section",
  "class": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Right side image"
    },
    {
      "type": "range",
      "id": "left_width",
      "min": 30,
      "max": 70,
      "step": 5,
      "default": 50,
      "unit": "%",
      "label": "Left column width"
    },
    {
      "type": "color",
      "id": "box_bg_color",
      "label": "Boxes background color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "box_text_color",
      "label": "Box text color",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "box_active_text_color",
      "label": "Active box text color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "box_font_size",
      "min": 12,
      "max": 40,
      "step": 1,
      "default": 20,
      "unit": "px",
      "label": "Box font size"
    },
    {
      "type": "range",
      "id": "box_font_weight",
      "min": 100,
      "max": 900,
      "step": 100,
      "default": 400,
      "label": "Box font weight"
    },
    {
      "type": "range",
      "id": "answer_font_size",
      "min": 12,
      "max": 40,
      "step": 1,
      "default": 16,
      "unit": "px",
      "label": "Answer font size"
    },
    {
      "type": "range",
      "id": "answer_font_weight",
      "min": 100,
      "max": 900,
      "step": 100,
      "default": 400,
      "label": "Answer font weight"
    },
    {
      "type": "color",
      "id": "answer_bg_color",
      "label": "Answer panel background color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "answer_text_color",
      "label": "Answer panel text color",
      "default": "#000000"
    }
  ],
  "blocks": [
    {
      "type": "info_box",
      "name": "Info Box",
      "limit": 50,
      "settings": [
        {
          "type": "richtext",
          "id": "heading",
          "label": "Box title",
          "default": "<p>Title</p>"
        },
        {
          "type": "richtext",
          "id": "answer",
          "label": "Answer content",
          "default": "<p>Answer text here</p>"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Kimao Info",
      "blocks": [
        {
          "type": "info_box",
          "settings": {
            "heading": "<p>Box 1</p>",
            "answer": "<p>Answer 1</p>"
          }
        },
        {
          "type": "info_box",
          "settings": {
            "heading": "<p>Box 2</p>",
            "answer": "<p>Answer 2</p>"
          }
        },
        {
          "type": "info_box",
          "settings": {
            "heading": "<p>Box 3</p>",
            "answer": "<p>Answer 3</p>"
          }
        }
      ]
    }
  ]
}
{% endschema %}
