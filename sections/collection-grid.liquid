<style>
  .collection-grid-{{ section.id }} {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    border: 1px solid #000;
    overflow: hidden;
    position: relative;
    z-index: 1;
  }

  .collection-grid-{{ section.id }} .cg-cell {
    position: relative;
    border: 1px solid #000;
    margin-left: -1px;
    margin-top: -1px;
    overflow: hidden;
  }

  .collection-grid-{{ section.id }} .cg-cell::before {
    content: '';
    display: block;
    padding-bottom: 133%;
  }

  .collection-grid-{{ section.id }} .cg-cell img,
  .collection-grid-{{ section.id }} .cg-cell svg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .collection-grid-{{ section.id }} .cg-cell--image {
    pointer-events: none;
  }

  .collection-grid-{{ section.id }} .cg-cell--product > a {
    position: absolute;
    inset: 0;
    display: block;
  }

  .collection-grid-{{ section.id }} .cg-cell--product > a img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  /* Hover drawer */
  .collection-grid-{{ section.id }} .cg-hover-drawer {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    background: rgb(var(--color-background));
    color: rgb(var(--color-foreground));
    padding: clamp(14px, 1vw, 20px) clamp(16px, 1.11vw, 22px);
    transform: translateY(100%);
    transition: transform 0.3s ease;
    z-index: 3;
    border-top: 1px solid #000;
  }

  @media (hover: hover) {
    .collection-grid-{{ section.id }} .cg-cell--product:hover .cg-hover-drawer {
      transform: translateY(0);
    }
  }

  .collection-grid-{{ section.id }} .cg-drawer-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 8px;
    margin: 0 0 12px;
  }

  .collection-grid-{{ section.id }} .cg-drawer-title {
    font-size: {{ section.settings.drawer_title_size }}px;
    font-weight: {{ section.settings.drawer_title_weight }};
    letter-spacing: {{ section.settings.drawer_title_letter_spacing | divided_by: 100.0 }}em;
    text-transform: {{ section.settings.drawer_title_transform }};
    line-height: 1.3;
    margin: 0;
  }

  .collection-grid-{{ section.id }} .cg-drawer-category {
    font-size: {{ section.settings.drawer_category_size }}px;
    font-weight: {{ section.settings.drawer_category_weight }};
    letter-spacing: {{ section.settings.drawer_category_letter_spacing | divided_by: 100.0 }}em;
    text-transform: {{ section.settings.drawer_category_transform }};
    opacity: 0.6;
    margin: 0;
    white-space: nowrap;
    flex-shrink: 0;
  }

  .collection-grid-{{ section.id }} .cg-drawer-form {
    margin: 0;
  }

  .collection-grid-{{ section.id }} .cg-drawer-atc {
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: 100%;
    padding: clamp(10px, 0.76vw, 14px) clamp(12px, 0.9vw, 16px);
    background: {{ section.settings.drawer_atc_bg }};
    color: {{ section.settings.drawer_atc_color }};
    border: none;
    border-radius: 0;
    cursor: pointer;
    transition: opacity 0.2s;
    margin-bottom: 8px;
  }

  .collection-grid-{{ section.id }} .cg-drawer-atc:hover {
    opacity: 0.85;
  }

  .collection-grid-{{ section.id }} .cg-drawer-atc[disabled] {
    opacity: 0.4;
    cursor: not-allowed;
  }

  .collection-grid-{{ section.id }} .cg-drawer-atc-label {
    font-size: {{ section.settings.drawer_atc_label_size }}px;
    font-weight: {{ section.settings.drawer_atc_label_weight }};
    letter-spacing: {{ section.settings.drawer_atc_label_letter_spacing | divided_by: 100.0 }}em;
    text-transform: {{ section.settings.drawer_atc_label_transform }};
  }

  .collection-grid-{{ section.id }} .cg-drawer-atc-price {
    font-size: {{ section.settings.drawer_atc_price_size }}px;
    font-weight: {{ section.settings.drawer_atc_price_weight }};
  }

  .collection-grid-{{ section.id }} .cg-drawer-link {
    display: inline-block;
    font-size: {{ section.settings.drawer_link_size }}px;
    font-weight: {{ section.settings.drawer_link_weight }};
    text-decoration: none;
    color: inherit;
    opacity: 0.7;
    transition: opacity 0.2s;
    letter-spacing: 0.04em;
  }

  .collection-grid-{{ section.id }} .cg-drawer-link:hover {
    opacity: 1;
  }

  /* Mobile-only price (desktop: hidden, price lives in ATC button) */
  .collection-grid-{{ section.id }} .cg-drawer-price {
    font-size: {{ section.settings.drawer_mob_price_size }}px;
    font-weight: {{ section.settings.drawer_mob_price_weight }};
    margin: 0;
    display: none;
  }

  /* Quick-add "+" button (mobile only) */
  .collection-grid-{{ section.id }} .cg-quick-add {
    display: none;
  }

  .collection-grid-{{ section.id }} .placeholder-svg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    background: #F5F4F1;
  }

  @media screen and (max-width: 749px) {
    .collection-grid-{{ section.id }} {
      grid-template-columns: 1fr 1fr;
    }

    /* Card becomes flex column: image on top, info below */
    .collection-grid-{{ section.id }} .cg-cell--product {
      display: flex;
      flex-direction: column;
    }

    .collection-grid-{{ section.id }} .cg-cell--product::before {
      display: none;
    }

    .collection-grid-{{ section.id }} .cg-cell--product > a {
      position: relative;
      inset: auto;
      display: block;
      aspect-ratio: 3 / 4;
    }

    .collection-grid-{{ section.id }} .cg-cell--product > a img {
      position: absolute;
      inset: 0;
    }

    /* Drawer becomes static info block below image */
    .collection-grid-{{ section.id }} .cg-hover-drawer {
      position: static;
      transform: none;
      transition: none;
      padding: 12px 14px;
      border-top: none;
    }

    .collection-grid-{{ section.id }} .cg-drawer-head {
      flex-direction: column;
      align-items: flex-start;
      gap: 2px;
      margin-bottom: 4px;
    }

    .collection-grid-{{ section.id }} .cg-drawer-title {
      font-size: {{ section.settings.drawer_mob_title_size }}px;
      font-weight: {{ section.settings.drawer_mob_title_weight }};
      letter-spacing: {{ section.settings.drawer_mob_title_letter_spacing | divided_by: 100.0 }}em;
      text-transform: {{ section.settings.drawer_mob_title_transform }};
    }

    .collection-grid-{{ section.id }} .cg-drawer-category {
      font-size: {{ section.settings.drawer_mob_category_size }}px;
      font-weight: {{ section.settings.drawer_mob_category_weight }};
      letter-spacing: {{ section.settings.drawer_mob_category_letter_spacing | divided_by: 100.0 }}em;
      text-transform: {{ section.settings.drawer_mob_category_transform }};
    }

    .collection-grid-{{ section.id }} .cg-drawer-price {
      display: block;
    }

    /* Hide desktop-only elements */
    .collection-grid-{{ section.id }} .cg-drawer-form {
      display: none;
    }

    .collection-grid-{{ section.id }} .cg-drawer-link {
      display: none;
    }

    /* Quick-add "+" button */
    .collection-grid-{{ section.id }} .cg-quick-add {
      display: flex;
      position: absolute;
      top: 0;
      right: 0;
      width: 40px;
      height: 40px;
      align-items: center;
      justify-content: center;
      background: rgb(var(--color-background));
      color: rgb(var(--color-foreground));
      border: 1px solid #000;
      border-top: none;
      border-right: none;
      font-size: 22px;
      line-height: 1;
      cursor: pointer;
      z-index: 4;
      padding: 0;
    }

    .collection-grid-{{ section.id }} .cg-quick-add:active {
      opacity: 0.6;
    }
  }
</style>

{%- liquid
  assign collection = section.settings.collection
  assign products_limit = section.settings.products_to_show
-%}

<div class="collection-grid-{{ section.id }} color-{{ section.settings.color_scheme }}">
  {%- comment -%} Grid 1: Decorative image {%- endcomment -%}
  <div class="cg-cell cg-cell--image">
    {%- if section.settings.grid_image != blank -%}
      <img
        src="{{ section.settings.grid_image | image_url: width: 600 }}"
        srcset="{{ section.settings.grid_image | image_url: width: 300 }} 300w,
                {{ section.settings.grid_image | image_url: width: 450 }} 450w,
                {{ section.settings.grid_image | image_url: width: 600 }} 600w"
        sizes="(max-width: 749px) 50vw, 33vw"
        alt="{{ section.settings.grid_image.alt | escape }}"
        width="{{ section.settings.grid_image.width }}"
        height="{{ section.settings.grid_image.height }}"
        loading="lazy"
      >
    {%- else -%}
      {{ 'lifestyle-1' | placeholder_svg_tag: 'placeholder-svg' }}
    {%- endif -%}
  </div>

  {%- comment -%} Grid 2+: Product cells {%- endcomment -%}
  {%- if collection != blank and collection.products.size > 0 -%}
    {%- for product in collection.products limit: products_limit -%}
      <div class="cg-cell cg-cell--product">
        <a href="{{ product.url }}">
          {%- if product.featured_image != blank -%}
            <img
              src="{{ product.featured_image | image_url: width: 600 }}"
              srcset="{{ product.featured_image | image_url: width: 300 }} 300w,
                      {{ product.featured_image | image_url: width: 450 }} 450w,
                      {{ product.featured_image | image_url: width: 600 }} 600w"
              sizes="(max-width: 749px) 50vw, 33vw"
              alt="{{ product.featured_image.alt | default: product.title | escape }}"
              width="{{ product.featured_image.width }}"
              height="{{ product.featured_image.height }}"
              loading="lazy"
            >
          {%- else -%}
            {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg' }}
          {%- endif -%}
        </a>
        <button class="cg-quick-add" type="button" aria-label="Sepete Ekle"
          data-variant-id="{{ product.selected_or_first_available_variant.id }}"
          {%- unless product.selected_or_first_available_variant.available %} disabled{% endunless %}>+</button>
        <div class="cg-hover-drawer color-{{ section.settings.drawer_color_scheme }}">
          <div class="cg-drawer-head">
            <p class="cg-drawer-title">{{ product.title }}</p>
            {%- if product.type != blank -%}
              <p class="cg-drawer-category">{{ product.type }}</p>
            {%- endif -%}
          </div>
          <p class="cg-drawer-price">{{ product.selected_or_first_available_variant.price | money }}</p>
          <form action="/cart/add" method="post" class="cg-drawer-form">
            <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">
            <button type="submit" class="cg-drawer-atc"
              {%- unless product.selected_or_first_available_variant.available %} disabled{% endunless %}>
              <span class="cg-drawer-atc-label">
                {%- if product.selected_or_first_available_variant.available -%}
                  Sepete Ekle
                {%- else -%}
                  Tükendi
                {%- endif -%}
              </span>
              <span class="cg-drawer-atc-price">{{ product.selected_or_first_available_variant.price | money }}</span>
            </button>
          </form>
          <a href="{{ product.url }}" class="cg-drawer-link">İncele →</a>
        </div>
      </div>
    {%- endfor -%}
  {%- else -%}
    {%- for i in (1..5) -%}
      <div class="cg-cell cg-cell--product">
        {{ 'product-apparel-' | append: i | placeholder_svg_tag: 'placeholder-svg' }}
      </div>
    {%- endfor -%}
  {%- endif -%}
</div>

<script>
(function() {
  var SECTION_ID = '{{ section.id }}';

  function init(container) {
    if (!container) return;

    /* Mobile "+" quick-add button */
    container.addEventListener('click', function(e) {
      var btn = e.target.closest('.cg-quick-add');
      if (!btn || btn.disabled) return;
      e.preventDefault();
      e.stopPropagation();
      btn.disabled = true;

      var variantId = btn.getAttribute('data-variant-id');
      var body = JSON.stringify({
        id: parseInt(variantId, 10),
        quantity: 1,
        sections: 'cart-drawer,cart-icon-bubble',
        sections_url: window.location.pathname
      });

      fetch('/cart/add.js', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          'X-Requested-With': 'XMLHttpRequest'
        },
        body: body
      })
      .then(function(res) {
        if (!res.ok) throw new Error('add failed');
        return res.json();
      })
      .then(function(data) {
        var cartDrawer = document.querySelector('cart-drawer');
        if (cartDrawer && cartDrawer.renderContents) {
          cartDrawer.renderContents(data);
          cartDrawer.classList.remove('is-empty');
        } else if (cartDrawer && cartDrawer.open) {
          cartDrawer.open();
        }
      })
      .catch(function(err) {
        console.error('CG quick-add error:', err);
      })
      .finally(function() {
        btn.disabled = false;
      });
    });

    /* Desktop ATC form submit */
    container.addEventListener('submit', function(e) {
      var form = e.target.closest('.cg-drawer-form');
      if (!form) return;
      e.preventDefault();

      var btn = form.querySelector('.cg-drawer-atc');
      if (btn && btn.disabled) return;
      if (btn) btn.disabled = true;

      var formData = new FormData(form);
      formData.append('sections', 'cart-drawer,cart-icon-bubble');
      formData.append('sections_url', window.location.pathname);

      fetch('/cart/add.js', {
        method: 'POST',
        headers: { 'X-Requested-With': 'XMLHttpRequest' },
        body: formData
      })
      .then(function(res) {
        if (!res.ok) throw new Error('add failed');
        return res.json();
      })
      .then(function(data) {
        var cartDrawer = document.querySelector('cart-drawer');
        if (cartDrawer && cartDrawer.renderContents) {
          cartDrawer.renderContents(data);
          cartDrawer.classList.remove('is-empty');
        } else if (cartDrawer && cartDrawer.open) {
          cartDrawer.open();
        }
      })
      .catch(function(err) {
        console.error('CG ATC error:', err);
        form.submit();
      })
      .finally(function() {
        if (btn) btn.disabled = false;
      });
    });
  }

  var el = document.querySelector('.collection-grid-' + SECTION_ID);
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', function() {
      init(document.querySelector('.collection-grid-' + SECTION_ID));
    });
  } else {
    init(el);
  }

  document.addEventListener('shopify:section:load', function(e) {
    if (e.detail.sectionId === SECTION_ID) {
      init(e.target.querySelector('.collection-grid-' + SECTION_ID));
    }
  });
})();
</script>

