<style>
  .kimao-anim-{{ section.id }} {
    position: relative;
    width: 100%;
    height: {{ section.settings.section_height }}vh;
    display: flex;
    justify-content: center;
    align-items: center;
    overflow: hidden;
    background-color: rgb(var(--color-background));
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
    {% if section.settings.bg_image != blank %}
      background-image: url('{{ section.settings.bg_image | image_url: width: 2000 }}');
    {% endif %}
  }

  .kimao-anim-{{ section.id }} .kimao-anim-overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: rgba(var(--color-background), {{ section.settings.overlay_opacity | divided_by: 100.0 }});
    pointer-events: none;
  }

  .kimao-anim-{{ section.id }} .kimao-anim-word {
    display: flex;
    align-items: baseline;
    justify-content: center;
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-weight: 700;
    font-size: {{ section.settings.font_size }}px;
    color: rgb(var(--color-foreground));
    letter-spacing: -5px;
    line-height: 1;
    z-index: 2;
  }

  .kimao-anim-{{ section.id }} .kimao-anim-char {
    position: relative;
    display: inline-block;
    overflow: hidden;
    padding: 0 2px;
    vertical-align: bottom;
    padding-top: 20px;
    margin-top: -20px;
  }

  .kimao-anim-{{ section.id }} .kimao-anim-char.reveal-bottom {
    animation: kimaoWipeUp-{{ section.id }} {{ section.settings.anim_speed }}s cubic-bezier(0.45, 0, 0.15, 1) infinite;
  }

  .kimao-anim-{{ section.id }} .kimao-anim-char.reveal-top {
    animation: kimaoWipeDown-{{ section.id }} {{ section.settings.anim_speed }}s cubic-bezier(0.45, 0, 0.15, 1) infinite;
  }

  @keyframes kimaoWipeUp-{{ section.id }} {
    0% {
      clip-path: inset(100% 0 -20% 0);
      transform: translateY(10px);
    }
    45% {
      clip-path: inset(-20% 0 -20% 0);
      transform: translateY(0);
    }
    55% {
      clip-path: inset(-20% 0 -20% 0);
      transform: translateY(0);
    }
    100% {
      clip-path: inset(-20% 0 100% 0);
      transform: translateY(-10px);
    }
  }

  @keyframes kimaoWipeDown-{{ section.id }} {
    0% {
      clip-path: inset(-20% 0 100% 0);
      transform: translateY(-10px);
    }
    45% {
      clip-path: inset(-20% 0 -20% 0);
      transform: translateY(0);
    }
    55% {
      clip-path: inset(-20% 0 -20% 0);
      transform: translateY(0);
    }
    100% {
      clip-path: inset(100% 0 -20% 0);
      transform: translateY(10px);
    }
  }

  @media (max-width: 749px) {
    .kimao-anim-{{ section.id }} {
      height: {{ section.settings.section_height_mobile }}vh;
    }
    .kimao-anim-{{ section.id }} .kimao-anim-word {
      font-size: {{ section.settings.font_size_mobile }}px;
      letter-spacing: -2px;
    }
    .kimao-anim-{{ section.id }} .kimao-anim-char {
      padding-top: 10px;
      margin-top: -10px;
    }
  }
</style>

<link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@700&display=swap" rel="stylesheet">

<div class="kimao-anim-{{ section.id }} color-{{ section.settings.color_scheme.id }}">
  <div class="kimao-anim-overlay"></div>
  <div class="kimao-anim-word">
    <span class="kimao-anim-char reveal-bottom">K</span>
    <span class="kimao-anim-char reveal-top">I</span>
    <span class="kimao-anim-char reveal-bottom">M</span>
    <span class="kimao-anim-char reveal-top">A</span>
    <span class="kimao-anim-char reveal-bottom">Ō</span>
  </div>
</div>

{% schema %}
{
  "name": "Kimao Girl Animation",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "range",
      "id": "section_height",
      "min": 30,
      "max": 100,
      "step": 5,
      "default": 100,
      "unit": "vh",
      "label": "Section height (desktop)"
    },
    {
      "type": "range",
      "id": "section_height_mobile",
      "min": 20,
      "max": 100,
      "step": 5,
      "default": 60,
      "unit": "vh",
      "label": "Section height (mobile)"
    },
    {
      "type": "image_picker",
      "id": "bg_image",
      "label": "Background image"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "min": 0,
      "max": 80,
      "step": 5,
      "default": 0,
      "unit": "%",
      "label": "Overlay opacity"
    },
    {
      "type": "range",
      "id": "font_size",
      "min": 80,
      "max": 300,
      "step": 10,
      "default": 150,
      "unit": "px",
      "label": "Font size (desktop)"
    },
    {
      "type": "range",
      "id": "font_size_mobile",
      "min": 30,
      "max": 120,
      "step": 5,
      "default": 60,
      "unit": "px",
      "label": "Font size (mobile)"
    },
    {
      "type": "range",
      "id": "anim_speed",
      "min": 2,
      "max": 12,
      "step": 1,
      "default": 8,
      "unit": "s",
      "label": "Animation speed"
    }
  ],
  "presets": [
    {
      "name": "Kimao Girl Animation"
    }
  ]
}
{% endschema %}
