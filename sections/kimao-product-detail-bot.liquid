<style>
  .kpdb-{{ section.id }} {
    background-color: rgb(var(--color-background));
    color: rgb(var(--color-foreground));
    border-top: 1px solid rgb(var(--color-foreground));
    border-bottom: 1px solid rgb(var(--color-foreground));
  }

  .kpdb-{{ section.id }} .kpdb__inner {
    display: flex;
    align-items: flex-start;
  }

  /* Left — Image (sticky) */
  .kpdb-{{ section.id }} .kpdb__left {
    width: {{ section.settings.split_left }}%;
    flex-shrink: 0;
    position: sticky;
    top: var(--header-height, 0px);
    height: calc(100vh - var(--header-height, 0px));
    border-right: 1px solid rgb(var(--color-foreground));
  }

  .kpdb-{{ section.id }} .kpdb__left img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .kpdb-{{ section.id }} .kpdb__left .kpdb__placeholder {
    width: 100%;
    height: 100%;
    background: rgba(var(--color-foreground), 0.06);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  /* Right — Text */
  .kpdb-{{ section.id }} .kpdb__right {
    flex: 1;
    padding: {{ section.settings.padding_y }}px {{ section.settings.padding_x }}px;
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: clamp(12px, 1.39vw, 24px);
  }

  .kpdb-{{ section.id }} .kpdb__title {
    font-size: clamp({{ section.settings.title_size | times: 0.75 | round }}px, {{ section.settings.title_size | divided_by: 14.4 }}vw, {{ section.settings.title_size | times: 1.3 | round }}px);
    font-weight: 700;
    line-height: 1.2;
    margin: 0;
    color: rgb(var(--color-foreground));
  }

  .kpdb-{{ section.id }} .kpdb__body {
    font-size: clamp({{ section.settings.body_size | times: 0.8 | round }}px, {{ section.settings.body_size | divided_by: 14.4 }}vw, {{ section.settings.body_size | times: 1.2 | round }}px);
    line-height: 1.65;
    color: rgb(var(--color-foreground));
  }

  .kpdb-{{ section.id }} .kpdb__body p {
    margin: 0 0 0.75em;
  }

  .kpdb-{{ section.id }} .kpdb__body p:last-child {
    margin-bottom: 0;
  }

  /* Mobile */
  @media (max-width: 749px) {
    .kpdb-{{ section.id }} .kpdb__inner {
      flex-direction: column;
    }

    .kpdb-{{ section.id }} .kpdb__left {
      width: 100%;
      flex-shrink: 0;
      position: static;
      height: {{ section.settings.mobile_image_height }}px;
      border-right: none;
      border-bottom: 1px solid rgb(var(--color-foreground));
    }

    .kpdb-{{ section.id }} .kpdb__left .kpdb__placeholder {
      min-height: {{ section.settings.mobile_image_height }}px;
    }

    .kpdb-{{ section.id }} .kpdb__right {
      padding: {{ section.settings.mobile_padding_y }}px {{ section.settings.mobile_padding_x }}px;
    }
  }
</style>

<div class="kpdb-{{ section.id }} color-{{ section.settings.color_scheme }}">
  <div class="kpdb__inner">

    {%- comment -%} Left — Image {%- endcomment -%}
    <div class="kpdb__left">
      {%- if section.settings.image != blank -%}
        <img
          src="{{ section.settings.image | image_url: width: 1200 }}"
          srcset="{{ section.settings.image | image_url: width: 600 }} 600w,
                  {{ section.settings.image | image_url: width: 900 }} 900w,
                  {{ section.settings.image | image_url: width: 1200 }} 1200w"
          sizes="{{ section.settings.split_left }}vw"
          alt="{{ section.settings.image.alt | escape }}"
          width="{{ section.settings.image.width }}"
          height="{{ section.settings.image.height }}"
          loading="lazy"
        >
      {%- else -%}
        <div class="kpdb__placeholder">
          {{ 'image' | placeholder_svg_tag }}
        </div>
      {%- endif -%}
    </div>

    {%- comment -%} Right — Text {%- endcomment -%}
    <div class="kpdb__right">
      {%- if section.settings.title != blank -%}
        <h2 class="kpdb__title">{{ section.settings.title }}</h2>
      {%- endif -%}
      {%- if section.settings.body != blank -%}
        <div class="kpdb__body">{{ section.settings.body }}</div>
      {%- endif -%}
    </div>

  </div>
</div>

{% schema %}
{
  "name": "Kimao Product Detail Bot",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "split_left",
      "min": 20,
      "max": 80,
      "step": 5,
      "unit": "%",
      "label": "Left column width",
      "default": 50
    },
    {
      "type": "header",
      "content": "Image"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "header",
      "content": "Text"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title"
    },
    {
      "type": "richtext",
      "id": "body",
      "label": "Body text"
    },
    {
      "type": "header",
      "content": "Font sizes"
    },
    {
      "type": "range",
      "id": "title_size",
      "min": 16,
      "max": 80,
      "step": 2,
      "unit": "px",
      "label": "Title font size",
      "default": 36
    },
    {
      "type": "range",
      "id": "body_size",
      "min": 10,
      "max": 24,
      "step": 1,
      "unit": "px",
      "label": "Body font size",
      "default": 15
    },
    {
      "type": "header",
      "content": "Desktop padding (text column)"
    },
    {
      "type": "range",
      "id": "padding_x",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Horizontal padding",
      "default": 48
    },
    {
      "type": "range",
      "id": "padding_y",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Vertical padding",
      "default": 48
    },
    {
      "type": "header",
      "content": "Mobile"
    },
    {
      "type": "range",
      "id": "mobile_image_height",
      "min": 160,
      "max": 600,
      "step": 20,
      "unit": "px",
      "label": "Image height (mobile)",
      "default": 300
    },
    {
      "type": "range",
      "id": "mobile_padding_x",
      "min": 0,
      "max": 60,
      "step": 4,
      "unit": "px",
      "label": "Horizontal padding (mobile)",
      "default": 20
    },
    {
      "type": "range",
      "id": "mobile_padding_y",
      "min": 0,
      "max": 60,
      "step": 4,
      "unit": "px",
      "label": "Vertical padding (mobile)",
      "default": 24
    }
  ],
  "presets": [
    {
      "name": "Kimao Product Detail Bot"
    }
  ]
}
{% endschema %}
