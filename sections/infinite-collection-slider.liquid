{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<style>
  .infinite-slider-{{ section.id }} {
    --slider-height: clamp({{ section.settings.slider_height }}px, {{ section.settings.slider_height | times: 100.0 | divided_by: 1440 | round: 2 }}vw, {{ section.settings.slider_height | times: 1.4 | round: 0 }}px);
    --card-width: clamp({{ section.settings.card_width }}px, {{ section.settings.card_width | times: 100.0 | divided_by: 1440 | round: 2 }}vw, {{ section.settings.card_width | times: 1.4 | round: 0 }}px);
    --wide-slide-width: clamp({{ section.settings.wide_slide_width }}px, {{ section.settings.wide_slide_width | times: 100.0 | divided_by: 1440 | round: 2 }}vw, {{ section.settings.wide_slide_width | times: 1.4 | round: 0 }}px);
    position: relative;
    overflow: hidden;
    width: 100%;
    z-index: 1;
  }

  /* Side panel */
  .infinite-slider-{{ section.id }} .inf-side-panel {
    position: absolute;
    left: 0;
    top: 0;
    width: clamp(70px, 4.86vw, 98px);
    height: 100%;
    background: rgb(var(--color-background));
    z-index: 2;
    display: flex;
    align-items: center;
    justify-content: center;
    pointer-events: none;
    border-right: 1px solid #000;
    border-top: 1px solid #000;
    border-bottom: 1px solid #000;
  }

  .infinite-slider-{{ section.id }} .inf-side-panel span {
    writing-mode: vertical-rl;
    transform: rotate(180deg);
    font-size: clamp(12px, 0.83vw, 17px);
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: rgb(var(--color-foreground));
    white-space: nowrap;
  }

  /* Track */
  .infinite-slider-{{ section.id }} .inf-track {
    display: flex;
    height: var(--slider-height);
    cursor: grab;
    will-change: transform;
    margin-left: clamp(70px, 4.86vw, 98px);
  }

  .infinite-slider-{{ section.id }} .inf-track.is-dragging {
    cursor: grabbing;
    user-select: none;
  }

  .infinite-slider-{{ section.id }} .inf-track.is-animating {
    transition: transform 0.35s cubic-bezier(0.16, 0.1, 0.12, 1);
  }

  /* Slide base */
  .infinite-slider-{{ section.id }} .inf-slide {
    flex-shrink: 0;
    height: 100%;
    border: 1px solid #000;
    margin-left: -1px;
    overflow: hidden;
    position: relative;
  }

  /* Product slide */
  .infinite-slider-{{ section.id }} .inf-slide--product {
    width: var(--card-width);
    background-color: rgb(var(--color-background));
    color: rgb(var(--color-foreground));
  }

  .infinite-slider-{{ section.id }} .inf-slide--product > a {
    display: block;
    width: 100%;
    height: 100%;
  }

  .infinite-slider-{{ section.id }} .inf-slide--product .placeholder-svg {
    width: 100%;
    height: 100%;
    background: #F5F4F1;
  }

  .infinite-slider-{{ section.id }} .inf-slide--product img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    pointer-events: none;
  }

  /* Hover drawer */
  .infinite-slider-{{ section.id }} .inf-hover-drawer {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    background: rgb(var(--color-background));
    color: rgb(var(--color-foreground));
    padding: clamp(14px, 1vw, 20px) clamp(16px, 1.11vw, 22px);
    transform: translateY(100%);
    transition: transform 0.3s ease;
    z-index: 3;
    border-top: 1px solid #000;
  }

  @media (hover: hover) {
    .infinite-slider-{{ section.id }} .inf-slide--product:hover .inf-hover-drawer {
      transform: translateY(0);
    }
  }

  .infinite-slider-{{ section.id }} .inf-drawer-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 8px;
    margin: 0 0 12px;
  }

  .infinite-slider-{{ section.id }} .inf-drawer-title {
    font-size: {{ section.settings.drawer_title_size }}px;
    font-weight: {{ section.settings.drawer_title_weight }};
    letter-spacing: {{ section.settings.drawer_title_letter_spacing | divided_by: 100.0 }}em;
    text-transform: {{ section.settings.drawer_title_transform }};
    line-height: 1.3;
    margin: 0;
  }

  .infinite-slider-{{ section.id }} .inf-drawer-category {
    font-size: {{ section.settings.drawer_category_size }}px;
    font-weight: {{ section.settings.drawer_category_weight }};
    letter-spacing: {{ section.settings.drawer_category_letter_spacing | divided_by: 100.0 }}em;
    text-transform: {{ section.settings.drawer_category_transform }};
    opacity: 0.6;
    margin: 0;
    white-space: nowrap;
    flex-shrink: 0;
  }

  .infinite-slider-{{ section.id }} .inf-drawer-form {
    margin: 0;
  }

  .infinite-slider-{{ section.id }} .inf-drawer-atc {
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: 100%;
    padding: clamp(10px, 0.76vw, 14px) clamp(12px, 0.9vw, 16px);
    background: {{ section.settings.drawer_atc_bg }};
    color: {{ section.settings.drawer_atc_color }};
    border: none;
    border-radius: 0;
    cursor: pointer;
    transition: opacity 0.2s;
    margin-bottom: 8px;
  }

  .infinite-slider-{{ section.id }} .inf-drawer-atc:hover {
    opacity: 0.85;
  }

  .infinite-slider-{{ section.id }} .inf-drawer-atc[disabled] {
    opacity: 0.4;
    cursor: not-allowed;
  }

  .infinite-slider-{{ section.id }} .inf-drawer-atc-label {
    font-size: {{ section.settings.drawer_atc_label_size }}px;
    font-weight: {{ section.settings.drawer_atc_label_weight }};
    letter-spacing: {{ section.settings.drawer_atc_label_letter_spacing | divided_by: 100.0 }}em;
    text-transform: {{ section.settings.drawer_atc_label_transform }};
  }

  .infinite-slider-{{ section.id }} .inf-drawer-atc-price {
    font-size: {{ section.settings.drawer_atc_price_size }}px;
    font-weight: {{ section.settings.drawer_atc_price_weight }};
  }

  .infinite-slider-{{ section.id }} .inf-drawer-link {
    display: inline-block;
    font-size: {{ section.settings.drawer_link_size }}px;
    font-weight: {{ section.settings.drawer_link_weight }};
    text-decoration: none;
    color: inherit;
    opacity: 0.7;
    transition: opacity 0.2s;
    letter-spacing: 0.04em;
  }

  .infinite-slider-{{ section.id }} .inf-drawer-link:hover {
    opacity: 1;
  }

  /* Mobile-only price (desktop: hidden, price lives in ATC button) */
  .infinite-slider-{{ section.id }} .inf-drawer-price {
    font-size: {{ section.settings.drawer_mob_price_size }}px;
    font-weight: {{ section.settings.drawer_mob_price_weight }};
    margin: 0;
    display: none;
  }

  /* Quick-add "+" button (mobile only) */
  .infinite-slider-{{ section.id }} .inf-quick-add {
    display: none;
  }

  /* Wide slide */
  .infinite-slider-{{ section.id }} .inf-slide--wide {
    width: var(--wide-slide-width);
    display: flex;
    align-items: flex-end;
    justify-content: flex-start;
    background: rgb(var(--color-background));
  }

  .infinite-slider-{{ section.id }} .inf-slide--wide img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    pointer-events: none;
  }

  .infinite-slider-{{ section.id }} .inf-slide--wide .inf-wide-text {
    position: relative;
    z-index: 2;
    padding: clamp(20px, 1.39vw, 28px) clamp(24px, 1.67vw, 34px);
    font-size: clamp(20px, 1.39vw, 28px);
    line-height: 1.2;
    color: rgb(var(--color-foreground));
  }

  /* Next button */
  .infinite-slider-{{ section.id }} .inf-next-btn {
    position: absolute;
    right: 12px;
    top: 50%;
    transform: translateY(-50%);
    width: clamp(44px, 3.06vw, 62px);
    height: clamp(44px, 3.06vw, 62px);
    border-radius: 0;
    z-index: 2;
    background: rgba(242, 233, 222, 0.9);
    border: 1px solid #000;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0;
  }

  .infinite-slider-{{ section.id }} .inf-next-btn .icon {
    width: clamp(16px, 1.11vw, 22px);
    height: clamp(16px, 1.11vw, 22px);
  }

  .infinite-slider-{{ section.id }} .inf-next-btn:hover {
    background: rgba(242, 233, 222, 1);
  }

  /* Mobile */
  @media screen and (max-width: 749px) {
    .infinite-slider-{{ section.id }} {
      --card-width: calc({{ section.settings.card_width }}px * 0.83);
    }

    /* Remove fixed track height, let slides determine it */
    .infinite-slider-{{ section.id }} .inf-track {
      height: auto;
      margin-left: 50px;
    }

    .infinite-slider-{{ section.id }} .inf-side-panel {
      width: 50px;
    }

    .infinite-slider-{{ section.id }} .inf-slide--wide {
      display: none;
    }

    /* Slide becomes flex column: image on top, info below */
    .infinite-slider-{{ section.id }} .inf-slide--product {
      display: flex;
      flex-direction: column;
      height: auto;
    }

    .infinite-slider-{{ section.id }} .inf-slide--product > a {
      display: block;
      width: 100%;
      height: auto;
      aspect-ratio: 3 / 4;
      position: relative;
    }

    .infinite-slider-{{ section.id }} .inf-slide--product > a img {
      position: absolute;
      inset: 0;
    }

    /* Drawer becomes static info block below image */
    .infinite-slider-{{ section.id }} .inf-hover-drawer {
      position: static;
      transform: none;
      transition: none;
      padding: 10px 12px;
      border-top: none;
    }

    .infinite-slider-{{ section.id }} .inf-drawer-head {
      flex-direction: column;
      align-items: flex-start;
      gap: 2px;
      margin-bottom: 4px;
    }

    .infinite-slider-{{ section.id }} .inf-drawer-title {
      font-size: {{ section.settings.drawer_mob_title_size }}px;
      font-weight: {{ section.settings.drawer_mob_title_weight }};
      letter-spacing: {{ section.settings.drawer_mob_title_letter_spacing | divided_by: 100.0 }}em;
      text-transform: {{ section.settings.drawer_mob_title_transform }};
    }

    .infinite-slider-{{ section.id }} .inf-drawer-category {
      font-size: {{ section.settings.drawer_mob_category_size }}px;
      font-weight: {{ section.settings.drawer_mob_category_weight }};
      letter-spacing: {{ section.settings.drawer_mob_category_letter_spacing | divided_by: 100.0 }}em;
      text-transform: {{ section.settings.drawer_mob_category_transform }};
    }

    .infinite-slider-{{ section.id }} .inf-drawer-price {
      display: block;
    }

    /* Hide desktop-only elements */
    .infinite-slider-{{ section.id }} .inf-drawer-form {
      display: none;
    }

    .infinite-slider-{{ section.id }} .inf-drawer-link {
      display: none;
    }

    /* Quick-add "+" button */
    .infinite-slider-{{ section.id }} .inf-quick-add {
      display: flex;
      position: absolute;
      top: 0;
      right: 0;
      width: 36px;
      height: 36px;
      align-items: center;
      justify-content: center;
      background: rgb(var(--color-background));
      color: rgb(var(--color-foreground));
      border: 1px solid #000;
      border-top: none;
      border-right: none;
      font-size: 20px;
      line-height: 1;
      cursor: pointer;
      z-index: 4;
      padding: 0;
    }

    .infinite-slider-{{ section.id }} .inf-quick-add:active {
      opacity: 0.6;
    }
  }
</style>

{%- liquid
  assign collection = section.settings.collection
  assign products_limit = section.settings.products_to_show
-%}

<div class="section-{{ section.id }}-padding">
  <div class="infinite-slider-{{ section.id }} color-{{ section.settings.color_scheme }}" data-section-id="{{ section.id }}">
    {%- comment -%} Side panel {%- endcomment -%}
    <div class="inf-side-panel">
      <span>{{ section.settings.side_text | escape }}</span>
    </div>

    {%- comment -%} Track {%- endcomment -%}
    <div class="inf-track" data-inf-track>
      {%- comment -%} Wide slide (static, desktop only) {%- endcomment -%}
      <div class="inf-slide inf-slide--wide" data-inf-wide{% unless section.settings.show_wide_slide %} style="display:none;"{% endunless %}>
        {%- if section.settings.wide_image != blank -%}
          <img
            src="{{ section.settings.wide_image | image_url: width: 900 }}"
            srcset="{{ section.settings.wide_image | image_url: width: 450 }} 450w,
                    {{ section.settings.wide_image | image_url: width: 900 }} 900w"
            sizes="(max-width: 749px) 0px, {{ section.settings.wide_slide_width }}px"
            alt="{{ section.settings.wide_image.alt | escape }}"
            width="{{ section.settings.wide_image.width }}"
            height="{{ section.settings.wide_image.height }}"
            loading="lazy"
          >
        {%- endif -%}
        <div class="inf-wide-text">{{ section.settings.wide_text }}</div>
      </div>

      {%- comment -%} Product slides {%- endcomment -%}
      {%- if collection != blank and collection.products.size > 0 -%}
        {%- for product in collection.products limit: products_limit -%}
          <div class="inf-slide inf-slide--product color-{{ section.settings.card_color_scheme }}" data-inf-product data-index="{{ forloop.index0 }}">
            <a href="{{ product.url }}">
              {%- if product.featured_image != blank -%}
                <img
                  src="{{ product.featured_image | image_url: width: 600 }}"
                  srcset="{{ product.featured_image | image_url: width: 300 }} 300w,
                          {{ product.featured_image | image_url: width: 450 }} 450w,
                          {{ product.featured_image | image_url: width: 600 }} 600w"
                  sizes="(max-width: 749px) {{ section.settings.card_width | times: 0.83 | round: 0 }}px, {{ section.settings.card_width }}px"
                  alt="{{ product.featured_image.alt | default: product.title | escape }}"
                  width="{{ product.featured_image.width }}"
                  height="{{ product.featured_image.height }}"
                  {% if forloop.first %}loading="eager" fetchpriority="high"{% else %}loading="lazy"{% endif %}
                >
              {%- else -%}
                {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg' }}
              {%- endif -%}
            </a>
            <button class="inf-quick-add" type="button" aria-label="Sepete Ekle"
              data-variant-id="{{ product.selected_or_first_available_variant.id }}"
              {%- unless product.selected_or_first_available_variant.available %} disabled{% endunless %}>+</button>
            <div class="inf-hover-drawer color-{{ section.settings.drawer_color_scheme }}">
              <div class="inf-drawer-head">
                <p class="inf-drawer-title">{{ product.title }}</p>
                {%- if product.type != blank -%}
                  <p class="inf-drawer-category">{{ product.type }}</p>
                {%- endif -%}
              </div>
              <p class="inf-drawer-price">{{ product.selected_or_first_available_variant.price | money }}</p>
              <form action="/cart/add" method="post" class="inf-drawer-form">
                <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">
                <button type="submit" class="inf-drawer-atc"
                  {%- unless product.selected_or_first_available_variant.available %} disabled{% endunless %}>
                  <span class="inf-drawer-atc-label">
                    {%- if product.selected_or_first_available_variant.available -%}
                      Sepete Ekle
                    {%- else -%}
                      Tükendi
                    {%- endif -%}
                  </span>
                  <span class="inf-drawer-atc-price">{{ product.selected_or_first_available_variant.price | money }}</span>
                </button>
              </form>
              <a href="{{ product.url }}" class="inf-drawer-link">İncele →</a>
            </div>
          </div>
        {%- endfor -%}
      {%- else -%}
        {%- for i in (1..4) -%}
          <div class="inf-slide inf-slide--product color-{{ section.settings.card_color_scheme }}" data-inf-product>
            {{ 'product-apparel-' | append: i | placeholder_svg_tag: 'placeholder-svg' }}
          </div>
        {%- endfor -%}
      {%- endif -%}
    </div>

    {%- comment -%} Next button {%- endcomment -%}
    <button class="inf-next-btn" data-inf-next aria-label="{{ 'general.slider.next_slide' | t }}">
      <span class="svg-wrapper">
        {{- 'icon-arrow.svg' | inline_asset_content -}}
      </span>
    </button>
  </div>
</div>

<script>
  (function() {
    var SECTION_ID = '{{ section.id }}';

    function init(container) {
      if (!container) return;

      var track = container.querySelector('[data-inf-track]');
      var nextBtn = container.querySelector('[data-inf-next]');
      if (!track) return;

      var origSlides = [];
      var visibleCount = 0;
      var offsets = [];       /* cumulative left-edge of each slide in the 3x track */
      var currentIndex = 0;   /* index within the MIDDLE (original) set */
      var animating = false;
      var isDragging = false;
      var dragStartX = 0;
      var dragCurrentX = 0;
      var startIndex = 0;
      var startTranslateX = 0;
      var THRESHOLD = 50;
      var resizeTimer = null;
      var touchStartY = 0;
      var touchLocked = false;  /* true = confirmed horizontal drag */
      var touchRejected = false; /* true = vertical scroll, ignore drag */

      /* Build track: [clone-set] [original-set] [clone-set] */
      function buildTrack() {
        var clones = track.querySelectorAll('[data-inf-clone]');
        for (var c = 0; c < clones.length; c++) {
          track.removeChild(clones[c]);
        }

        origSlides = Array.prototype.slice.call(
          track.querySelectorAll('.inf-slide:not([data-inf-clone])')
        );

        var visibleSlides = origSlides.filter(function(s) {
          return s.offsetWidth > 0;
        });
        visibleCount = visibleSlides.length;

        /* Prepend clone set */
        for (var i = visibleSlides.length - 1; i >= 0; i--) {
          var pre = visibleSlides[i].cloneNode(true);
          pre.setAttribute('data-inf-clone', 'pre');
          pre.querySelectorAll('a').forEach(function(a) { a.setAttribute('tabindex', '-1'); });
          track.insertBefore(pre, track.firstChild);
        }

        /* Append clone set */
        for (var j = 0; j < visibleSlides.length; j++) {
          var post = visibleSlides[j].cloneNode(true);
          post.setAttribute('data-inf-clone', 'post');
          post.querySelectorAll('a').forEach(function(a) { a.setAttribute('tabindex', '-1'); });
          track.appendChild(post);
        }
      }

      /* Build offset table: the exact left-edge pixel of every slide in the 3x track */
      function measure() {
        offsets = [];
        var allSlides = Array.prototype.slice.call(track.children);
        var cumulative = 0;
        for (var i = 0; i < allSlides.length; i++) {
          var w = allSlides[i].getBoundingClientRect().width;
          if (w === 0) continue;  /* skip hidden (wide slide on mobile) */
          offsets.push(cumulative);
          /* -1px margin collapse */
          cumulative += w - 1;
        }

        /* On resize: keep current position; only reset to 0 on first build */
        if (currentIndex >= visibleCount) currentIndex = 0;
        applySnapPosition(false);
      }

      /* Given a logical index (0 = first original slide), compute the translateX
         so that slide's left edge aligns with the side panel's right edge */
      function getTranslateForIndex(idx) {
        /* The middle set starts at offset position [visibleCount] in the offsets array */
        var realIdx = visibleCount + idx;
        if (realIdx < 0 || realIdx >= offsets.length) realIdx = visibleCount;
        return -offsets[realIdx];
      }

      function applySnapPosition(animate) {
        var tx = getTranslateForIndex(currentIndex);
        if (animate) {
          track.classList.add('is-animating');
        } else {
          track.classList.remove('is-animating');
        }
        track.style.transform = 'translateX(' + tx + 'px)';
      }

      function applyRawTranslate(px) {
        track.classList.remove('is-animating');
        track.style.transform = 'translateX(' + px + 'px)';
      }

      /* Move by one slide */
      function slideByOne(dir) {
        if (animating) return;
        animating = true;
        currentIndex += dir;
        applySnapPosition(true);
      }

      /* After animation: wrap index back into original set range */
      function onTransitionEnd() {
        track.classList.remove('is-animating');
        animating = false;

        /* Wrap: if index went beyond original set, teleport silently */
        if (currentIndex >= visibleCount) {
          currentIndex -= visibleCount;
          applySnapPosition(false);
        } else if (currentIndex < 0) {
          currentIndex += visibleCount;
          applySnapPosition(false);
        }
      }

      /* Read current computed translateX from the browser */
      function getCurrentTranslateX() {
        var st = window.getComputedStyle(track);
        var matrix = st.transform || st.webkitTransform;
        if (matrix && matrix !== 'none') {
          var vals = matrix.match(/matrix.*\((.+)\)/);
          if (vals) {
            var parts = vals[1].split(', ');
            return parseFloat(parts[4]) || 0;
          }
        }
        return 0;
      }

      /* Find the closest logical index for a given translateX pixel value */
      function findClosestIndex(tx) {
        var best = 0;
        var bestDist = Infinity;
        for (var i = -visibleCount; i < visibleCount * 2; i++) {
          var candidate = getTranslateForIndex(i);
          var dist = Math.abs(candidate - tx);
          if (dist < bestDist) {
            bestDist = dist;
            best = i;
          }
        }
        return best;
      }

      /* Drag */
      function onDragStart(x) {
        /* If animating, cancel animation and grab from current position */
        if (animating) {
          var liveX = getCurrentTranslateX();
          track.classList.remove('is-animating');
          track.style.transform = 'translateX(' + liveX + 'px)';
          currentIndex = findClosestIndex(liveX);
          animating = false;
        }
        isDragging = true;
        dragStartX = x;
        dragCurrentX = x;
        startIndex = currentIndex;
        startTranslateX = getTranslateForIndex(currentIndex);
        track.classList.add('is-dragging');
      }

      function onDragMove(x) {
        if (!isDragging) return;
        dragCurrentX = x;
        var diff = dragCurrentX - dragStartX;
        applyRawTranslate(startTranslateX + diff);
      }

      function onDragEnd() {
        if (!isDragging) return;
        isDragging = false;
        track.classList.remove('is-dragging');
        var diff = dragCurrentX - dragStartX;

        if (Math.abs(diff) > THRESHOLD) {
          /* dragged right = previous slide, dragged left = next slide */
          currentIndex = startIndex + (diff > 0 ? -1 : 1);
        } else {
          currentIndex = startIndex;
        }
        animating = true;
        applySnapPosition(true);
      }

      /* Mouse events */
      track.addEventListener('mousedown', function(e) {
        e.preventDefault();
        onDragStart(e.clientX);
      });
      window.addEventListener('mousemove', function(e) {
        if (!isDragging) return;
        e.preventDefault();
        onDragMove(e.clientX);
      });
      window.addEventListener('mouseup', function() {
        onDragEnd();
      });

      /* Touch events with vertical/horizontal intent detection */
      track.addEventListener('touchstart', function(e) {
        touchStartY = e.touches[0].clientY;
        touchLocked = false;
        touchRejected = false;
        onDragStart(e.touches[0].clientX);
      }, { passive: true });
      track.addEventListener('touchmove', function(e) {
        if (!isDragging || touchRejected) return;
        var dx = Math.abs(e.touches[0].clientX - dragStartX);
        var dy = Math.abs(e.touches[0].clientY - touchStartY);
        /* First significant move: decide direction */
        if (!touchLocked && (dx > 8 || dy > 8)) {
          if (dy > dx) {
            /* Vertical intent — cancel drag, let browser scroll */
            touchRejected = true;
            isDragging = false;
            track.classList.remove('is-dragging');
            applySnapPosition(false);
            return;
          }
          touchLocked = true;
        }
        if (touchLocked) {
          onDragMove(e.touches[0].clientX);
        }
      }, { passive: true });
      track.addEventListener('touchend', function() {
        if (touchRejected) return;
        onDragEnd();
      });

      /* Prevent click after drag */
      track.addEventListener('click', function(e) {
        if (Math.abs(dragCurrentX - dragStartX) > 5) {
          e.preventDefault();
          e.stopPropagation();
        }
      }, true);

      /* Transition end */
      track.addEventListener('transitionend', onTransitionEnd);

      /* Next button */
      if (nextBtn) {
        nextBtn.addEventListener('click', function() {
          slideByOne(1);
        });
      }

      /* Mobile "+" quick-add button */
      container.addEventListener('click', function(e) {
        var btn = e.target.closest('.inf-quick-add');
        if (!btn || btn.disabled) return;
        e.preventDefault();
        e.stopPropagation();
        btn.disabled = true;

        var variantId = btn.getAttribute('data-variant-id');
        var body = JSON.stringify({
          id: parseInt(variantId, 10),
          quantity: 1,
          sections: 'cart-drawer,cart-icon-bubble',
          sections_url: window.location.pathname
        });

        fetch('/cart/add.js', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
            'X-Requested-With': 'XMLHttpRequest'
          },
          body: body
        })
        .then(function(res) {
          if (!res.ok) throw new Error('add failed');
          return res.json();
        })
        .then(function(data) {
          var cartDrawer = document.querySelector('cart-drawer');
          if (cartDrawer && cartDrawer.renderContents) {
            cartDrawer.renderContents(data);
            cartDrawer.classList.remove('is-empty');
          } else if (cartDrawer && cartDrawer.open) {
            cartDrawer.open();
          }
        })
        .catch(function(err) {
          console.error('Slider quick-add error:', err);
        })
        .finally(function() {
          btn.disabled = false;
        });
      });

      /* AJAX Add to Cart for hover drawer */
      container.addEventListener('submit', function(e) {
        var form = e.target.closest('.inf-drawer-form');
        if (!form) return;
        e.preventDefault();

        var btn = form.querySelector('.inf-drawer-atc');
        if (btn && btn.disabled) return;
        if (btn) btn.disabled = true;

        var formData = new FormData(form);
        formData.append('sections', 'cart-drawer,cart-icon-bubble');
        formData.append('sections_url', window.location.pathname);

        fetch('/cart/add.js', {
          method: 'POST',
          headers: { 'X-Requested-With': 'XMLHttpRequest' },
          body: formData
        })
        .then(function(res) {
          if (!res.ok) throw new Error('add failed');
          return res.json();
        })
        .then(function(data) {
          var cartDrawer = document.querySelector('cart-drawer');
          if (cartDrawer && cartDrawer.renderContents) {
            cartDrawer.renderContents(data);
            cartDrawer.classList.remove('is-empty');
          } else if (cartDrawer && cartDrawer.open) {
            cartDrawer.open();
          }
        })
        .catch(function(err) {
          console.error('Slider ATC error:', err);
          form.submit();
        })
        .finally(function() {
          if (btn) btn.disabled = false;
        });
      });

      /* Resize */
      window.addEventListener('resize', function() {
        clearTimeout(resizeTimer);
        resizeTimer = setTimeout(function() {
          buildTrack();
          measure();
        }, 250);
      });

      /* Go */
      buildTrack();
      measure();
    }

    /* Initial load */
    var el = document.querySelector('.infinite-slider-' + SECTION_ID);
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', function() {
        init(document.querySelector('.infinite-slider-' + SECTION_ID));
      });
    } else {
      init(el);
    }

    /* Shopify editor reload */
    document.addEventListener('shopify:section:load', function(e) {
      if (e.detail.sectionId === SECTION_ID) {
        init(e.target.querySelector('.infinite-slider-' + SECTION_ID));
      }
    });
  })();
</script>

