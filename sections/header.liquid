<style>
  header-drawer {
    justify-self: start;
    margin-left: -1.2rem;
  }

  {%- if section.settings.sticky_header_type == 'reduce-logo-size' -%}
    .scrolled-past-header .header__heading-logo-wrapper {
      width: 75%;
    }
  {%- endif -%}

  /* Kimao: burger menu always visible on all screen sizes */

  .menu-drawer-container {
    display: flex;
  }

  .list-menu {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .list-menu--inline {
    display: inline-flex;
    flex-wrap: wrap;
  }

  summary.list-menu__item {
    padding-right: 2.7rem;
  }

  .list-menu__item {
    display: flex;
    align-items: center;
    line-height: calc(1 + 0.3 / var(--font-body-scale));
  }

  .list-menu__item--link {
    text-decoration: none;
    padding-bottom: 1rem;
    padding-top: 1rem;
    line-height: calc(1 + 0.8 / var(--font-body-scale));
  }

  @media screen and (min-width: 1000px) {
    .list-menu__item--link {
      padding-bottom: 0.5rem;
      padding-top: 0.5rem;
    }
  }
</style>

{%- style -%}
  .header {
    padding: {{ section.settings.padding_top | times: 0.5 | round: 0 }}px 3rem {{ section.settings.padding_bottom | times: 0.5 | round: 0 }}px 3rem;
  }

  .section-header {
    position: sticky; /* This is for fixing a Safari z-index issue. PR #2147 */
    margin-bottom: {{ section.settings.margin_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 1000px) {
    .section-header {
      margin-bottom: {{ section.settings.margin_bottom }}px;
    }
  }

  @media screen and (min-width: 990px) {
    .header {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  /* Kimao: Fixed 70px header */
  .header-wrapper {
    border-bottom: 1px solid rgba(var(--color-foreground), 1) !important;
  }

  .header {
    height: 70px;
    padding: 0 25px !important;
    max-width: 100% !important;
    box-sizing: border-box;
    align-items: center;
  }

  /* Left group: burger + nav links in one grid cell */
  .kimao-header-left {
    grid-area: navigation;
    display: flex;
    align-items: center;
    height: 70px;
    gap: 0.5rem;
  }

  /* Icons: align to bottom with shared padding */
  .header__icons {
    align-self: end;
    padding-bottom: 15px;
  }

  /* Force burger visible on desktop */
  @media screen and (min-width: 990px) {
    header-drawer {
      display: flex !important;
    }
  }

  /* Nav link spacing and styling — same padding-bottom as icons */
  .kimao-nav-left {
    display: flex;
    margin-top: auto;
    padding-bottom: 11px;
    line-height: 1;
  }

  .kimao-nav-left .list-menu--inline {
    gap: calc(1.5rem + 4px);
    margin-left: 10px;
  }

  .kimao-nav-link {
    position: relative;
    display: inline-block;
    overflow: hidden;
    font-size: 19px;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    text-decoration: none;
    color: rgb(var(--color-foreground));
    font-weight: {{ section.settings.nav_link_font_weight }};
  }

  .kimao-nav-text {
    display: block;
    transition: transform 0.45s ease, opacity 0.45s ease;
  }

  {% assign w = section.settings.nav_link_font_weight | plus: 0 %}
  {% if w >= 700 %}{% assign hover_w = 900 %}
  {% elsif w >= 600 %}{% assign hover_w = 700 %}
  {% elsif w >= 500 %}{% assign hover_w = 600 %}
  {% elsif w >= 400 %}{% assign hover_w = 500 %}
  {% else %}{% assign hover_w = 400 %}{% endif %}

  .kimao-nav-text--bold {
    position: absolute;
    left: 0;
    top: 0;
    font-weight: {{ hover_w }};
    transform: translateY(-140%);
    opacity: 0;
  }

  .kimao-nav-link:hover .kimao-nav-text--normal {
    transform: translateY(140%);
    opacity: 0;
  }

  .kimao-nav-link:hover .kimao-nav-text--bold {
    transform: translateY(0);
    opacity: 1;
  }

  @media screen and (max-width: 1100px) {
    .kimao-nav-link {
      font-size: 17px;
    }
  }

  /* Right icons: align right + bottom */
  .header__icons {
    justify-self: end;
  }

  /* Logo sizing */
  .header__heading-logo {
    height: 40px;
    width: auto;
  }

  /* Mobile: hide collection links, fix burger placement, logo left */
  @media screen and (max-width: 999px) {
    .kimao-nav-left {
      display: none;
    }

    /* Mobile grid: logo sol, burger+ikonlar sağ */
    .header {
      grid-template-areas: 'heading icons left-icons' !important;
      grid-template-columns: auto 1fr auto !important;
    }

    /* Burger: sağa hizala */
    .kimao-header-left {
      grid-area: left-icons;
    }
    header-drawer {
      justify-self: end;
      margin-left: 0;
    }

    /* Logo left-aligned on mobile */
    .header__heading,
    .header__heading-link {
      text-align: left !important;
      justify-self: start !important;
    }
  }
{%- endstyle -%}

<script src="{{ 'cart-notification.js' | asset_url }}" defer="defer"></script>

{%- liquid
  for block in section.blocks
    if block.type == '@app'
      assign has_app_block = true
    endif
  endfor
-%}

{% liquid
  assign header_tag = 'div'

  if section.settings.sticky_header_type != 'none'
    assign header_tag = 'sticky-header'
  endif
%}

