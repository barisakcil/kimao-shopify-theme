{% comment %}theme-check-disable UndefinedObject{% endcomment %}
{{ 'section-footer.css' | asset_url | stylesheet_tag }}
{{ 'component-newsletter.css' | asset_url | stylesheet_tag }}
{{ 'component-list-menu.css' | asset_url | stylesheet_tag }}
{{ 'component-list-payment.css' | asset_url | stylesheet_tag }}
{{ 'component-list-social.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .kimao-footer {
    margin-top: {{ section.settings.margin_top | times: 0.75 | round: 0 }}px;
  }

  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .kimao-footer {
      margin-top: {{ section.settings.margin_top }}px;
    }

    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

{%- liquid
  assign bg_color = section.settings.background_color | default: '#F2E9DE'
  assign border_color = section.settings.border_color | default: '#000000'

  assign has_social_icons = true
  if settings.social_facebook_link == blank and settings.social_instagram_link == blank and settings.social_youtube_link == blank and settings.social_tiktok_link == blank and settings.social_twitter_link == blank and settings.social_pinterest_link == blank and settings.social_snapchat_link == blank and settings.social_tumblr_link == blank and settings.social_vimeo_link == blank
    assign has_social_icons = false
  endif
-%}

<footer class="kimao-footer section-{{ section.id }}-padding" style="background-color: {{ bg_color }}; --kimao-border-color: {{ border_color }};">

  {%- comment -%} ===== TOP: 3 Column Menu Area ===== {%- endcomment -%}
  <div class="kimao-footer__columns">

    {%- comment -%} Left Column — Info {%- endcomment -%}
    <div class="kimao-footer__column kimao-footer__column--left">
      <div class="kimao-footer__heading" onclick="kimaoFooterAccordion(this)">
        <h2 class="kimao-footer__title">{{ section.settings.left_heading | default: 'Info' }}</h2>
        <span class="kimao-footer__accordion-arrow">+</span>
      </div>
      <ul class="kimao-footer__links">
        <li><a href="/pages/s-s-s" class="kimao-footer__link">S.S.S.</a></li>
        <li><a href="/pages/kargo-iade-degisim" class="kimao-footer__link">KARGO İADE DEĞİŞİM</a></li>
        <li><a href="/pages/iletisim" class="kimao-footer__link">İLETİŞİM</a></li>
        <li><a href="/policies" class="kimao-footer__link">POLİTİKALAR</a></li>
        <li><a href="/account" class="kimao-footer__link">HESABIM</a></li>
      </ul>
    </div>

    {%- comment -%} Middle Column — Mağaza {%- endcomment -%}
    <div class="kimao-footer__column kimao-footer__column--right">
      <div class="kimao-footer__heading" onclick="kimaoFooterAccordion(this)">
        <h2 class="kimao-footer__title">{{ section.settings.right_heading | default: 'Mağaza' }}</h2>
        <span class="kimao-footer__accordion-arrow">+</span>
      </div>
      <ul class="kimao-footer__links">
        <li><a href="/collections/serum" class="kimao-footer__link">SERUM</a></li>
        <li><a href="/collections/krem" class="kimao-footer__link">KREM</a></li>
        <li><a href="/collections/tonik" class="kimao-footer__link">TONİK</a></li>
        <li><a href="/collections/set-bundle" class="kimao-footer__link">SET/BUNDLE</a></li>
      </ul>
    </div>

    {%- comment -%} Right Column — Medya {%- endcomment -%}
    <div class="kimao-footer__column kimao-footer__column--media">

      {%- comment -%} Content: heading + social links {%- endcomment -%}
      <div class="ki-media-content">
        <div class="kimao-footer__heading" onclick="kimaoFooterAccordion(this)">
          <h2 class="kimao-footer__title">{{ section.settings.media_heading | default: 'Medya' }}</h2>
          <span class="kimao-footer__accordion-arrow">+</span>
        </div>
        {%- if section.settings.show_social and has_social_icons -%}
          <ul class="kimao-footer__links ki-social-links">
            {%- if settings.social_instagram_link != blank -%}
              <li>
                <a href="{{ settings.social_instagram_link }}" class="kimao-footer__link ki-social-link" target="_blank" rel="noopener noreferrer">
                  <span class="svg-wrapper ki-social-icon">{{- 'icon-instagram.svg' | inline_asset_content -}}</span>
                  <span>Instagram</span>
                </a>
              </li>
            {%- endif -%}
            {%- if settings.social_youtube_link != blank -%}
              <li>
                <a href="{{ settings.social_youtube_link }}" class="kimao-footer__link ki-social-link" target="_blank" rel="noopener noreferrer">
                  <span class="svg-wrapper ki-social-icon">{{- 'icon-youtube.svg' | inline_asset_content -}}</span>
                  <span>YouTube</span>
                </a>
              </li>
            {%- endif -%}
            {%- if settings.social_facebook_link != blank -%}
              <li>
                <a href="{{ settings.social_facebook_link }}" class="kimao-footer__link ki-social-link" target="_blank" rel="noopener noreferrer">
                  <span class="svg-wrapper ki-social-icon">{{- 'icon-facebook.svg' | inline_asset_content -}}</span>
                  <span>Facebook</span>
                </a>
              </li>
            {%- endif -%}
            {%- if settings.social_tiktok_link != blank -%}
              <li>
                <a href="{{ settings.social_tiktok_link }}" class="kimao-footer__link ki-social-link" target="_blank" rel="noopener noreferrer">
                  <span class="svg-wrapper ki-social-icon">{{- 'icon-tiktok.svg' | inline_asset_content -}}</span>
                  <span>TikTok</span>
                </a>
              </li>
            {%- endif -%}
            {%- if settings.social_pinterest_link != blank -%}
              <li>
                <a href="{{ settings.social_pinterest_link }}" class="kimao-footer__link ki-social-link" target="_blank" rel="noopener noreferrer">
                  <span class="svg-wrapper ki-social-icon">{{- 'icon-pinterest.svg' | inline_asset_content -}}</span>
                  <span>Pinterest</span>
                </a>
              </li>
            {%- endif -%}
          </ul>
        {%- endif -%}
      </div>

      {%- comment -%} Credits: vertical text — desktop only {%- endcomment -%}
      <div class="ki-media-credits">
        <span class="ki-credits-text">SITE CREDITS</span>
        <span class="ki-credits-text">©{{ 'now' | date: '%Y' }} KIMAŌ</span>
      </div>

    </div>

  </div>

  {%- comment -%} ===== Newsletter / Follow on Shop ===== {%- endcomment -%}
  {%- if section.settings.newsletter_enable or section.settings.enable_follow_on_shop -%}
    <div class="kimao-footer__extras section-{{ section.id }}-padding">
      {%- if section.settings.newsletter_enable -%}
        <div class="kimao-footer__newsletter">
          {%- if section.settings.newsletter_heading != blank -%}
            <h2 class="footer-block__heading inline-richtext">{{ section.settings.newsletter_heading }}</h2>
          {%- endif -%}
          {%- form 'customer', id: 'ContactFooter', class: 'footer__newsletter newsletter-form' -%}
            <input type="hidden" name="contact[tags]" value="newsletter">
            <div class="newsletter-form__field-wrapper">
              <div class="field">
                <input
                  id="NewsletterForm--{{ section.id }}"
                  type="email"
                  name="contact[email]"
                  class="field__input"
                  value="{{ form.email }}"
                  aria-required="true"
                  autocorrect="off"
                  autocapitalize="off"
                  autocomplete="email"
                  {% if form.errors %}
                    autofocus
                    aria-invalid="true"
                    aria-describedby="ContactFooter-error"
                  {% elsif form.posted_successfully? %}
                    aria-describedby="ContactFooter-success"
                  {% endif %}
                  placeholder="{{ 'newsletter.label' | t }}"
                  required
                >
                <label class="field__label" for="NewsletterForm--{{ section.id }}">
                  {{ 'newsletter.label' | t }}
                </label>
                <button
                  type="submit"
                  class="newsletter-form__button field__button"
                  name="commit"
                  id="Subscribe"
                  aria-label="{{ 'newsletter.button_label' | t }}"
                >
                  <span class="svg-wrapper">
                    {{- 'icon-arrow.svg' | inline_asset_content -}}
                  </span>
                </button>
              </div>
              {%- if form.errors -%}
                <small class="newsletter-form__message form__message" id="ContactFooter-error">
                  <span class="svg-wrapper">{{- 'icon-error.svg' | inline_asset_content -}}</span>
                  {{- form.errors.translated_fields.email | capitalize }}
                  {{ form.errors.messages.email -}}
                </small>
              {%- endif -%}
            </div>
            {%- if form.posted_successfully? -%}
              <h3 class="newsletter-form__message newsletter-form__message--success form__message" id="ContactFooter-success" tabindex="-1" autofocus>
                <span class="svg-wrapper">{{- 'icon-success.svg' | inline_asset_content -}}</span>
                {{- 'newsletter.success' | t }}
              </h3>
            {%- endif -%}
          {%- endform -%}
        </div>
      {%- endif -%}

      {%- if shop.features.follow_on_shop? and section.settings.enable_follow_on_shop -%}
        <div class="footer__follow-on-shop">
          {{ shop | login_button: action: 'follow' }}
        </div>
      {%- endif -%}
    </div>
  {%- endif -%}

  {%- comment -%} ===== Mobile Bottom: Social Icons + Credits ===== {%- endcomment -%}
  <div class="ki-mobile-bottom">
    {%- if section.settings.show_social and has_social_icons -%}
      <div class="ki-mobile-social">
        {%- if settings.social_instagram_link != blank -%}
          <a href="{{ settings.social_instagram_link }}" class="ki-mobile-social__link" target="_blank" rel="noopener noreferrer">
            <span class="svg-wrapper">{{- 'icon-instagram.svg' | inline_asset_content -}}</span>
          </a>
        {%- endif -%}
        {%- if settings.social_youtube_link != blank -%}
          <a href="{{ settings.social_youtube_link }}" class="ki-mobile-social__link" target="_blank" rel="noopener noreferrer">
            <span class="svg-wrapper">{{- 'icon-youtube.svg' | inline_asset_content -}}</span>
          </a>
        {%- endif -%}
        {%- if settings.social_facebook_link != blank -%}
          <a href="{{ settings.social_facebook_link }}" class="ki-mobile-social__link" target="_blank" rel="noopener noreferrer">
            <span class="svg-wrapper">{{- 'icon-facebook.svg' | inline_asset_content -}}</span>
          </a>
        {%- endif -%}
        {%- if settings.social_tiktok_link != blank -%}
          <a href="{{ settings.social_tiktok_link }}" class="ki-mobile-social__link" target="_blank" rel="noopener noreferrer">
            <span class="svg-wrapper">{{- 'icon-tiktok.svg' | inline_asset_content -}}</span>
          </a>
        {%- endif -%}
        {%- if settings.social_pinterest_link != blank -%}
          <a href="{{ settings.social_pinterest_link }}" class="ki-mobile-social__link" target="_blank" rel="noopener noreferrer">
            <span class="svg-wrapper">{{- 'icon-pinterest.svg' | inline_asset_content -}}</span>
          </a>
        {%- endif -%}
      </div>
    {%- endif -%}
    <div class="ki-mobile-credits">
      <span>SITE CREDITS</span>
      <span>©{{ 'now' | date: '%Y' }} KIMAŌ</span>
    </div>
  </div>

</footer>

<script>
  function kimaoFooterAccordion(el) {
    if (window.innerWidth > 1000) return;
    var arrow = el.querySelector('.kimao-footer__accordion-arrow');
    var links = el.nextElementSibling;
    if (!links) return;
    var isActive = el.classList.toggle('active');
    links.classList.toggle('open');
    arrow.textContent = isActive ? '✕' : '+';
    arrow.style.fontSize = isActive ? '28px' : '40px';
  }
</script>

{% schema %}
{
  "name": "t:sections.footer.name",
  "settings": [
    {
      "type": "header",
      "content": "Left Column"
    },
    {
      "type": "text",
      "id": "left_heading",
      "label": "Left Heading",
      "default": "Info"
    },
    {
      "type": "link_list",
      "id": "left_menu",
      "label": "Left Menu",
      "default": "footer"
    },
    {
      "type": "header",
      "content": "Middle Column"
    },
    {
      "type": "text",
      "id": "right_heading",
      "label": "Middle Heading",
      "default": "Mağaza"
    },
    {
      "type": "link_list",
      "id": "right_menu",
      "label": "Middle Menu",
      "default": "footer"
    },
    {
      "type": "header",
      "content": "Media Column"
    },
    {
      "type": "text",
      "id": "media_heading",
      "label": "Media Heading",
      "default": "Medya"
    },
    {
      "type": "checkbox",
      "id": "show_social",
      "default": false,
      "label": "t:sections.footer.settings.show_social.label",
      "info": "t:sections.footer.settings.show_social.info"
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background Color",
      "default": "#F2E9DE"
    },
    {
      "type": "color",
      "id": "border_color",
      "label": "Border Color",
      "default": "#000000"
    },
    {
      "type": "header",
      "content": "t:sections.footer.settings.header__1.content",
      "info": "t:sections.footer.settings.header__1.info"
    },
    {
      "type": "checkbox",
      "id": "newsletter_enable",
      "default": false,
      "label": "t:sections.footer.settings.newsletter_enable.label"
    },
    {
      "type": "inline_richtext",
      "id": "newsletter_heading",
      "default": "t:sections.footer.settings.newsletter_heading.default",
      "label": "t:sections.footer.settings.newsletter_heading.label"
    },
    {
      "type": "header",
      "content": "t:sections.footer.settings.header__9.content"
    },
    {
      "type": "checkbox",
      "id": "enable_follow_on_shop",
      "default": false,
      "label": "t:sections.footer.settings.enable_follow_on_shop.label",
      "info": "t:sections.footer.settings.enable_follow_on_shop.info"
    },
    {
      "type": "checkbox",
      "id": "enable_country_selector",
      "default": false,
      "label": "t:sections.footer.settings.enable_country_selector.label",
      "info": "t:sections.footer.settings.enable_country_selector.info"
    },
    {
      "type": "checkbox",
      "id": "enable_language_selector",
      "default": false,
      "label": "t:sections.footer.settings.enable_language_selector.label",
      "info": "t:sections.footer.settings.enable_language_selector.info"
    },
    {
      "type": "header",
      "content": "t:sections.all.spacing"
    },
    {
      "type": "range",
      "id": "margin_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.footer.settings.margin_top.label",
      "default": 0
    },
    {
      "type": "header",
      "content": "t:sections.all.padding.section_padding_heading"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_top",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_bottom",
      "default": 0
    }
  ]
}
{% endschema %}
